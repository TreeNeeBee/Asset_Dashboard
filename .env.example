# Database — switch between sqlite (dev) and postgres (prod)
DATABASE_URL=sqlite+aiosqlite:///./asset_dashboard.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/asset_db

# API Keys (optional – free tiers work without keys for most providers)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
ALPHA_VANTAGE_API_KEY=demo
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Scheduler interval (seconds)
FETCH_INTERVAL=300
